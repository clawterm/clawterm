{
  "name": "clawterm",
  "private": true,
  "version": "0.18.2",
  "description": "A terminal emulator for managing multiple AI agents — vertical tabs with live status, split panes, and desktop notifications.",
  "homepage": "https://clawterm.github.io/clawterm",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawterm/clawterm.git"
  },
  "author": "Clawterm Contributors",
  "license": "MIT",
  "keywords": [
    "terminal",
    "ai-agents",
    "tauri",
    "xterm",
    "split-panes",
    "developer-tools"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:backend": "cd src-tauri && cargo test",
    "preflight": "npm run lint && npm run format:check && npm run test && npx tsc --noEmit && npm run test:backend",
    "release": "node scripts/release.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "tauri-pty": "^0.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
